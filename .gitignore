# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Test and type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Build artifacts
dist/
build/
*.egg-info/
node_modules/

# Virtual environments
.venv/
venv/
env/

# Environment files
.env
.env.*
!.env.example

# Potentially sensitive JSON exports/credentials
*.secret.json
*.secrets.json
*credentials*.json
*service-account*.json
*private*.json

# Editor folders
.vscode/
.idea/

# OS files
.DS_Store

# Logs
*.log

# Generated QA/debug artifacts
test-results/
reports/browser_qa/
reports/library_leaf_remove_fix_report.sample.json
reports/library_leaf_remove_fix_report.slice180.json
templates/index_backup.html
error_audit.txt
sefardic_prayers.json

# Sefaria local cache (runtime-generated)
.sefaria_cache/

# Ignore all hidden files and folders by default
.*
**/.*

# explicit exceptions to force Claude to view these specific hidden folders
!.agents/
!.claude/
!.github/
!.pre-commit-config.yaml
