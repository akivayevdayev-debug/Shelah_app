# Flask runtime
FLASK_SECRET_KEY=replace-with-a-long-random-secret
PORT=5001

# Anthropic / Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
AI_MAX_INPUT_CHARS=1200
AI_MAX_PROMPT_CHARS=16000
AI_MAX_RESPONSE_WORDS=500
AI_MAX_RESPONSE_CHARS=20000

# Rate limiting
# Optional global limits for all routes (comma-separated), leave empty for no global cap
RATE_LIMIT_DEFAULT=
RATE_LIMIT_ASK=20 per minute
RATELIMIT_STORAGE_URI=memory://

# Clerk
CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_JWT_ISSUER=
CLERK_AUDIENCE=
CLERK_ENFORCE_AUTH=false

# Supabase
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PREFS_TABLE=user_preferences

# Runtime behavior
RESOURCE_RELOAD_SECONDS=300
SESSION_RELOAD_SECONDS=900
